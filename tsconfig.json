{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"allowJs": false,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": [
		"src/main/**/*.ts",
		"src/main/**/*.d.ts",
		"test/**/*.ts",
		"vite.config.ts",
		"vite.browser.config.ts",
		"eslint.config.js"
	]
}
